{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(git status)",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git remote -v)",
      "Bash(git ls-files:*)",
      "Bash(git rev-parse:*)",
      "Bash(git blame:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(cmake -S . -B build*)",
      "Bash(cmake --build build*)",
      "Bash(ctest:*)"
    ],
    "deny": [
      "Bash(git push:*)",
      "Bash(git push)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./**/credentials.*)",
      "Read(./**/*.pem)",
      "Read(./**/*.key)",
      "Read(./**/id_rsa*)",
      "Write(./.env)",
      "Write(./.env.*)",
      "Write(./**/credentials.*)",
      "Write(./**/*.pem)",
      "Write(./**/*.key)",
      "Edit(./.env)",
      "Edit(./.env.*)",
      "Edit(./**/credentials.*)",
      "Edit(./**/*.pem)",
      "Edit(./**/*.key)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "echo '[PM] session-start: bootstrap files auto-load via CLAUDE.md'"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'cmd=\"${CLAUDE_TOOL_INPUT:-}\"; case \"$cmd\" in *\"git push\"*) echo \"[PM] BLOCKED: git push is denied by PREFERENCES.md\" >&2; exit 2;; *\"git commit\"*) echo \"[PM] pre-commit: scanning staged files for secrets...\"; if git diff --cached -U0 | grep -E \"(api[_-]?key|secret|password|token|BEGIN (RSA|OPENSSH|EC) PRIVATE KEY)\" -i >/dev/null; then echo \"[PM] BLOCKED: potential secret in staged diff\" >&2; exit 2; fi;; esac; exit 0'"
          }
        ]
      }
    ]
  }
}
